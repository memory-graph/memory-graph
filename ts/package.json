{
  "name": "memorygraph",
  "version": "0.13.0",
  "description": "Graph-based memory CLI for AI coding agents with intelligent relationship tracking and multi-backend support",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "memorygraph": "src/cli.ts"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build src/cli.ts --compile --outfile memorygraph",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "falkordb": "^6.0.0",
    "falkordblite": "^0.1.0",
    "neo4j-driver": "^6.2.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.5.0"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "license": "MIT",
  "keywords": [
    "memory",
    "knowledge-graph",
    "falkordb",
    "coding-agent",
    "context",
    "relationships"
  ],
  "trustedDependencies": [
    "falkordblite"
  ]
}
